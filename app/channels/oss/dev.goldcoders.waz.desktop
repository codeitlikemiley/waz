[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=Waz
GenericName=TerminalEmulator

# `waz` 在 deb/rpm 包里是 /opt/waz/waz-oss 的 symlink,
# 在 arch 包里是 /usr/bin/waz wrapper script —— 三者都在 PATH 上能直接调用。
# AppImage 打包时 bundle_appimage 会用 sed 把这一行替换为 `Exec=waz-oss %U`,
# 直接指向 AppImage 内部的二进制。
Exec=waz %U
StartupWMClass=dev.waz.Waz

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.waz.Waz

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for waz:// URLs.
MimeType=x-scheme-handler/waz;
